{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "solvedProblems": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of problem IDs solved by the user" 
        },
        "lastActive": { "type": "number", "description": "Last active timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Problem": {
      "title": "Problem",
      "description": "DSA problem details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "starterCode": { "type": "string" },
        "solution": { "type": "string" }
      },
      "required": ["id", "title", "difficulty", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and progress tracking"
    },
    "/problems/{problemId}": {
      "schema": "Problem",
      "description": "Curated list of DSA problems"
    }
  }
}
